# ============================================================================
# 本番環境 (prd) - 変数値
# このファイルをコピーして terraform.tfvars を作成する:
#   cp terraform.tfvars.example terraform.tfvars
# ============================================================================

# GCP
gcp_project_id = "prd-nekomeshi"
gcp_region     = "asia-northeast1"
support_email  = ""  # OAuth 同意画面に表示するメールアドレス

# Supabase
supabase_project_ref  = ""  # Supabase Dashboard からプロジェクトの Reference ID を取得
supabase_access_token = ""  # https://supabase.com/dashboard/account/tokens で生成

# OAuth（GCP Console > APIs & Services > Credentials で作成）
google_oauth_client_id     = ""
google_oauth_client_secret = ""

# アプリケーション
app_url = "https://nekomeshi.app"
